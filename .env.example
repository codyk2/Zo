# Cactus / Gemma 4 (on-device, primary)
# Leave defaults if you installed cactus via `cactus build --python` into ~/cactus/
# Gemma 4 E4B is multimodal — it handles voice transcription, vision, AND
# tool-calling for the router. One model does everything.
CACTUS_PYTHON_PATH=~/cactus/python/src
CACTUS_WEIGHTS_PATH=~/cactus/weights/gemma-4-e4b-it

# Whisper-base — on-device transcription (142 MB, ~200ms, good accuracy).
# Alternatives: whisper-tiny (62 MB, faster but sloppier),
# whisper-small (244 MB, best accuracy).
CACTUS_WHISPER_WEIGHTS_PATH=~/cactus/weights/whisper-base

# Ollama fallback (only used if Cactus unavailable)
OLLAMA_URL=http://localhost:11434
GEMMA_MODEL=gemma4:e4b

# AWS Bedrock (Claude) — escalate_to_cloud path
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MODEL_ID_HEAVY=anthropic.claude-sonnet-4-20250514-v1:0

# ElevenLabs
ELEVENLABS_API_KEY=your_key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Gemini — voice-transcription cloud fallback (hackathon Step 8-10)
# gemini-2.5-flash supports audio input + is available with hackathon credits
GEMINI_API_KEY=your_key
GEMINI_MODEL=gemini-2.5-flash

# RunPod — pod-side services
RUNPOD_API_KEY=your_key
RUNPOD_POD_IP=your_pod_ip
RUNPOD_LIVETALKING_PORT=8010
RUNPOD_TRIPOSR_PORT=8020

# Lip-sync servers (via SSH tunnel by default; set LIPSYNC_HOST=<pod-ip> for direct)
LIPSYNC_HOST=127.0.0.1
WAV2LIP_PORT=8010
LATENTSYNC_PORT=8766
POD_SPEAKING_1080P=/workspace/state_pitching_pose_speaking_1080p.mp4

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DASHBOARD_PORT=5173

# ── Avatar realism feature flags (Apr 18 build) ─────────────────────────────
# Each behavioural change for the YC demo ships behind a flag so we can
# disable any single piece without redeploying. Defaults are ON.
USE_AUDIO_FIRST=1            # comment_response_audio event + background Wav2Lip
USE_KARAOKE=1                # word-by-word captions on the stage
USE_PITCH_VEO=1              # 30s pre-rendered Veo pitch + TTS overlay
USE_BACKCHANNEL=1            # listening_attentive pose on mic press (visual only)
USE_SPECULATIVE_BRIDGE=1     # short ack clip after transcript, before router
LIPSYNC_PROVIDER=wav2lip     # only wav2lip today; future: musetalk hook
